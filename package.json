{
  "name": "smp-tamhar-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:mobile": "vite --port=3001 --host=0.0.0.0 --mode mobile",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "build": "npm run generate:pwa-icons && vite build",
    "pack:deploy": "powershell -ExecutionPolicy Bypass -File scripts/create-deploy-zip.ps1",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "setup:supabase": "node scripts/setup-supabase-schema.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "html2canvas-pro": "^2.2.1",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/jsbarcode": "^3.11.4",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "pg": "^8.22.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
